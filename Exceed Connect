        <!-- FAQs & Support -->
        <section class="faq-container">
            <div>
                <div class="section-header"><div class="section-indicator"></div><h2 class="section-title">FAQs</h2></div>
                <details><summary>Annual Training Access?</summary><div class="answer">Click 'Annual Training' and log in with ELP Google credentials.</div></details>
                <details><summary>Trust Policies?</summary><div class="answer">Statutory policies are located in the 'Exceed Policy' hub.</div></details>
                <details><summary>Digital Support?</summary><div class="answer">Log a support ticket via the IT Support Request button in the Reporting tray.</div></details>
                <details><summary>Reporting an Accident?</summary><div class="answer">All staff must record workplace accidents or near-misses immediately using the 'Accident' button in the Reporting tray.</div></details>
                <details><summary>Managing a Complaint?</summary><div class="answer">For guidance on handling formal complaints, please access the 'Managing Complaints' resource in the Reporting section.</div></details>
                <details><summary>Accessing Professional Learning?</summary><div class="answer">Visit the Professional Learning section to view available CPD pathways, Trust-wide development days, and LinkedIn Learning access.</div></details>
            </div>
            <div class="support-box">
                <svg class="svg-icon" style="width:36px;height:36px;opacity:0.2;position:absolute;bottom:-8px;right:-8px" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" x2="12.01" y1="17" y2="17"/></svg>
                <h3>Need Help?</h3><p>Contact central support for navigation assistance.</p>
                <a href="mailto:connect@elp.org.uk" class="btn-email"><svg class="svg-icon" viewBox="0 0 24 24"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>Email Support</a>
            </div>
        </section>
    </main>

    <script>
        const URL_CONFIG = {
            "link-banner-faq": { url: "https://sites.google.com/exceedlp.org.uk/exceedconnect/elp-connect-faqs", target: "_self" },
            "link-gmail": { url: "https://mail.google.com", target: "_blank" },
            "link-calendar": { url: "https://calendar.google.com", target: "_blank" },
            "link-docs": { url: "https://docs.google.com", target: "_blank" },
            "link-sheets": { url: "https://sheets.google.com", target: "_blank" },
            "link-slides": { url: "https://slides.google.com", target: "_blank" },
            "link-drive": { url: "https://drive.google.com", target: "_blank" },
            "link-arbor": { url: "https://sites.google.com/exceedlp.org.uk/exceedconnect/arbor", target: "_blank" },
            "link-it-support": { url: "https://support.example.com", target: "_blank" },
            "link-breach": { url: "https://breach.example.com", target: "_blank" },
            "link-accident": { url: "https://accident.example.com", target: "_blank" },
            "link-complaints": { url: "https://complaints.example.com", target: "_blank" },
            "link-myelp": { url: "https://sites.google.com/exceedlp.org.uk/exceedconnect/my-elp", target: "_self" },
            "link-wellbeing": { url: "https://sites.google.com/exceedlp.org.uk/exceedconnect/wellbeing-services", target: "_self" },
            "link-ess-news": { url: "https://sites.google.com/exceedlp.org.uk/exceedconnect/news-coming-soon", target: "_self" },
            "link-news-archive": { url: "https://sites.google.com/exceedlp.org.uk/exceedconnect/news-archive", target: "_self" },
            "link-guide": { url: "https://sites.google.com/hallcrossacademy.co.uk/theelpguide/home", target: "_self" },
            "link-leadership": { url: "https://sites.google.com/elp.org.uk/leadershipframework?usp=sharing", target: "_self" },
            "link-events": { url: "https://sites.google.com/hallcrossacademy.co.uk/theelpguide/home", target: "_self" },
            "link-sol-comms": { url: "https://sites.google.com/exceedlp.org.uk/exceedconnect/exceed-solutions/departments/exceed-communications", target: "_self" },
            "link-sol-data": { url: "https://sites.google.com/exceedlp.org.uk/exceedconnect/exceed-solutions/exceed-data-security-hub", target: "_self" },
            "link-sol-tech": { url: "https://sites.google.com/exceedlp.org.uk/exceedconnect/exceed-solutions/exceed-technology", target: "_self" },
            "link-sol-estates": { url: "https://sites.google.com/exceedlp.org.uk/exceedconnect/exceed-estates", target: "_self" },
            "link-sol-finance": { url: "https://sites.google.com/exceedlp.org.uk/exceedconnect/exceed-solutions/exceed-financial", target: "_self" },
            "link-sol-people": { url: "https://sites.google.com/exceedlp.org.uk/exceedconnect/exceed-solutions/exceed-people", target: "_self" },
            "link-sol-policy": { url: "https://sites.google.com/exceedlp.org.uk/exceedconnect/policy-insight", target: "_self" },
            "link-sol-safeguarding": { url: "https://sites.google.com/exceedlp.org.uk/exceedconnect/exceed-solutions/safeguarding", target: "_self" },
            "link-sol-school-imp": { url: "https://sites.google.com/exceedlp.org.uk/exceedconnect/exceed-school-improvement", target: "_self" },
            "link-sol-all": { url: "https://sites.google.com/exceedlp.org.uk/exceedconnect/exceed-solutions", target: "_self" },
            "link-gov-main": { url: "https://sites.google.com/exceedlp.org.uk/exceedconnect/exceed-solutions/governance-hub", target: "_self" },
            "link-gov-legal": { url: "https://sites.google.com/exceedlp.org.uk/exceedconnect/exceed-solutions/departments/exceed-legal", target: "_self" },
            "link-pd-annual": { url: "#", target: "_self" },
            "link-pd-learning": { url: "https://sites.google.com/exceedlp.org.uk/exceedconnect/professional-learning", target: "_self" },
            "link-pd-linkedin": { url: "https://www.linkedin.com/learning", target: "_self" }
        };

        const ICONS = {
            internal: '<svg class="news-source-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>',
            external: '<svg class="news-source-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20"/><path d="M12 2a14.5 14.5 0 0 1 0 20"/><path d="M2 12h20"/></svg>'
        };

        function applyConfigLinks() {
            for (const id in URL_CONFIG) {
                const element = document.getElementById(id);
                if (element) {
                    element.href = URL_CONFIG[id].url;
                    element.target = URL_CONFIG[id].target;
                }
            }
        }

        async function fetchNews() {
            const container = document.getElementById('news-container');
            const csvUrl = 'https://docs.google.com/spreadsheets/d/1PhZXVKbASeiETb5XQEhXwD4ULZ2aUb2_Og8dZ9_qvVM/export?format=csv';
            
            try {
                const response = await fetch(csvUrl);
                if (!response.ok) throw new Error('Network error');
                const csvText = await response.text();
                const rows = csvText.split(/\r?\n/).filter(row => row.trim() !== '');
                const newsItems = rows.slice(1);
                
                if (newsItems.length === 0) {
                    container.innerHTML = '<div style="font-size: 11px; color: var(--text-muted); padding-left: 8px;">No current news items.</div>';
                    return;
                }

                let html = '';
                newsItems.forEach(row => {
                    const cols = row.split(/,(?=(?:(?:[^"]*"){2})*[^"]*$)/);
                    if (cols.length >= 3) {
                        const title = cols[0].replace(/^"|"$/g, '').trim();
                        const date = cols[1].replace(/^"|"$/g, '').trim();
                        const headline = cols[2].replace(/^"|"$/g, '').trim();
                        const url = (cols[3] ? cols[3].replace(/^"|"$/g, '').trim() : '#');
                        const source = (cols[4] ? cols[4].replace(/^"|"$/g, '').trim().toLowerCase() : 'internal');
                        const sourceIcon = source === 'external' ? ICONS.external : ICONS.internal;

                        html += `<a href="${url}" ${url !== '#' ? 'target="_blank"' : ''} class="news-card"><div class="news-header-meta"><span class="news-tag">${title}</span>${sourceIcon}</div><h3 class="news-headline">${headline}</h3><span class="news-date">${date}</span></a>`;
                    }
                });
                container.innerHTML = html;
            } catch (err) {
                container.innerHTML = '<div style="font-size: 11px; color: var(--rose); padding-left: 8px;">Failed to load latest news.</div>';
            }
        }
        
        window.addEventListener('DOMContentLoaded', () => {
            applyConfigLinks();
            fetchNews();
        });
    </script>
</body>
</html>
